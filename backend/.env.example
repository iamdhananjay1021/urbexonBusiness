# # ─── App ────────────────────────────────────────────────
# NODE_ENV=production
# PORT=9000

# # ─── Database ───────────────────────────────────────────
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# # ─── JWT ────────────────────────────────────────────────
# # IMPORTANT: Use a secure random string (min 32 characters)
# JWT_SECRET=your_secure_jwt_secret_key_minimum_32_characters_very_long_and_secure_key

# # ─── Frontend URLs (CORS whitelist) ─────────────────────
# FRONTEND_URL=https://urbexon.in
# ADMIN_FRONTEND_URL=https://admin.urbexon.in
# VENDOR_FRONTEND_URL=https://vendor.urbexon.in
# DELIVERY_FRONTEND_URL=https://delivery.partner.urbexon.in
# CLIENT_URL=https://urbexon.in

# # ─── Cloudinary ─────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# # ─── Email (Resend) ──────────────────────────────────────
# RESEND_API_KEY=your_resend_api_key
# FROM_EMAIL=support@urbexon.in
# FROM_NAME=Urbexon Team

# # ─── Razorpay ────────────────────────────────────────────
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# # ─── Shiprocket ──────────────────────────────────────────
# SHIPROCKET_EMAIL=your_shiprocket_email@example.com
# SHIPROCKET_PASSWORD=your_shiprocket_password
# SHIPROCKET_PICKUP_LOCATION=Primary

# # ─── Shop Info ───────────────────────────────────────────
# SHOP_NAME=Urbexon
# SHOP_EMAIL=support@urbexon.in
# SHOP_PHONE=+918808485840
# SHOP_WEBSITE=urbexon.in
# SHOP_PINCODE=224122

# # ─── Admin Email ─────────────────────────────────────────
# ADMIN_EMAIL=admin@urbexon.in

# # ─── Redis (optional — falls back to in-memory if not set) ──────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

