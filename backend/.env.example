# Backend environment example for Urbexon

# --- App keys ---
JWT_SECRET=your_long_secure_jwt_secret_here
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.example.mongodb.net/urbexon

# --- Preferred: Resend (API) ---
# If you choose Resend to send email, set this key and follow Resend's domain verification UI
RESEND_API_KEY=
FROM_EMAIL=team@yourdomain.com
FROM_NAME=Urbexon Team

# --- Fallback: SMTP ---
# If you don't use Resend, configure SMTP credentials to use nodemailer fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false # set to 'true' for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=team@yourdomain.com

# --- Optional ---
CLIENT_URL=https://urbexon.in
VENDOR_VITE_API_URL =https://vendor.urbexon.in
ADMIN_VITE_API_URL =https://admin.urbexon.in
DELIVERY_VITE_API_URL =https://delivery.partner.urbexon.in

# DNS / domain verification notes (summary):
# 1) Add an SPF TXT record for your sending domain: e.g.
#    v=spf1 include:spf.resend.com include:_spf.your-smtp-provider.com -all
# 2) Add DKIM records (Resend or your SMTP provider will give DKIM CNAME/TXT entries).
# 3) Add any provider-specific CNAME/TXT records required by Resend (from the Resend dashboard).
# 4) Wait for DNS propagation and domain verification in the provider dashboard.
# 5) Use the verified `FROM_EMAIL` (same domain) in the environment.

# After filling values, restart the backend server to apply changes.
