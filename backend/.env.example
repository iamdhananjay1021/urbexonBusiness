# Backend environment example for Urbexon
# Every variable below is either required at boot (server.js fails fast if
# missing) or actually read somewhere in the codebase — this file is kept
# in sync with `grep -r "process.env\." backend/` on every audit pass.

# ══════════════════════════════════════════════════════════
# REQUIRED — server.js exits at boot if any of these are missing
# ══════════════════════════════════════════════════════════
JWT_SECRET=your_long_secure_jwt_secret_here_min_32_chars
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.example.mongodb.net/urbexon

# Razorpay — payment capture + refunds (refundEngine.js, Paymentcontroller.js)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Verifies inbound Razorpay webhook signatures (Paymentcontroller.js) — set
# this to the same secret configured in the Razorpay dashboard webhook.
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary — every image/document upload in the app (config/cloudinary.js)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ══════════════════════════════════════════════════════════
# RECOMMENDED — server boots without these but the feature degrades
# ══════════════════════════════════════════════════════════

# Redis — falls back to in-memory NodeCache if unset (utils/Cache.js)
REDIS_URL=

# --- Preferred: Resend (API) ---
RESEND_API_KEY=
FROM_EMAIL=team@yourdomain.com
FROM_NAME=Urbexon Team

# --- Fallback: SMTP (used only if RESEND_API_KEY is unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=team@yourdomain.com

# ══════════════════════════════════════════════════════════
# WhatsApp (Meta Cloud API) — utils/whatsapp.js
# Leave WHATSAPP_PROVIDER unset/=console to no-op (dev default).
# ══════════════════════════════════════════════════════════
WHATSAPP_PROVIDER=console
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_TEMPLATE_NAME=
# Receives admin-facing WhatsApp alerts (utils/whatsapp.js)
ADMIN_WHATSAPP_NUMBER=

# ══════════════════════════════════════════════════════════
# Shiprocket — ecommerce shipping integration (utils/Shiprocketservice.js)
# Leave SHIPROCKET_MOCK=true to no-op in dev without real credentials.
# ══════════════════════════════════════════════════════════
SHIPROCKET_MOCK=true
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_SECRET=

# ══════════════════════════════════════════════════════════
# Firebase — push notifications (config/firebase.js). Provide either a full
# service-account JSON string, or point at a credentials file on disk.
# ══════════════════════════════════════════════════════════
FIREBASE_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=

# ══════════════════════════════════════════════════════════
# Shop / invoice details — used on every generated invoice PDF/email
# (utils/invoiceEmailHelper.js). Blank values silently produce a blank
# invoice header if not set.
# ══════════════════════════════════════════════════════════
SHOP_NAME=Urbexon
SHOP_TAGLINE=
SHOP_ADDRESS=
SHOP_CITY=
SHOP_STATE_CODE=
SHOP_PINCODE=224122
SHOP_GSTIN=
SHOP_PHONE=
SHOP_EMAIL=
SHOP_WEBSITE=https://urbexon.in

# ══════════════════════════════════════════════════════════
# Frontend origins / panel URLs
# ══════════════════════════════════════════════════════════
CLIENT_URL=https://urbexon.in
ADMIN_URL=https://admin.urbexon.in
VENDOR_URL=https://vendor.urbexon.in
DELIVERY_URL=https://delivery.partner.urbexon.in
VENDOR_VITE_API_URL=https://vendor.urbexon.in
ADMIN_VITE_API_URL=https://admin.urbexon.in
DELIVERY_VITE_API_URL=https://delivery.partner.urbexon.in

# Cookie domain for refresh-token cookies (authController.js) — set to your
# apex domain (e.g. .urbexon.in) in production so panels on subdomains can
# share the cookie; leave unset for local development.
COOKIE_DOMAIN=

# ══════════════════════════════════════════════════════════
# Operational
# ══════════════════════════════════════════════════════════
NODE_ENV=production
PORT=9000

# Notified on admin-facing order/return alert emails (orderController.js,
# Paymentcontroller.js)
ADMIN_EMAIL=

# Hours a COD order can sit unconfirmed before the auto-cancel job cancels it
# (jobs/orderInventoryJobs.js)
COD_CANCEL_HOURS=48

# Rate limiting — all optional, sane defaults are baked into server.js if
# unset. Never set DISABLE_RATE_LIMIT in production.
RL_AUTH_MAX=30
RL_PUBLIC_MAX=200
RL_GENERAL_MAX=120
RL_ADMIN_MAX=150
DISABLE_RATE_LIMIT=

# Error tracking (optional) — see config/errorTracking.js. Leave unset to
# no-op; set to enable Sentry-compatible error reporting in production.
SENTRY_DSN=

# ══════════════════════════════════════════════════════════
# DNS / domain verification notes (email deliverability)
# ══════════════════════════════════════════════════════════
# 1) Add an SPF TXT record for your sending domain: e.g.
#    v=spf1 include:spf.resend.com include:_spf.your-smtp-provider.com -all
# 2) Add DKIM records (Resend or your SMTP provider will give DKIM CNAME/TXT entries).
# 3) Add any provider-specific CNAME/TXT records required by Resend (from the Resend dashboard).
# 4) Wait for DNS propagation and domain verification in the provider dashboard.
# 5) Use the verified `FROM_EMAIL` (same domain) in the environment.
#
# After filling values, restart the backend server to apply changes.
