# Environment Variables for Location System

# ============================================================================
# GOOGLE MAPS API (Optional - for better reverse geocoding)
# ============================================================================

# Get from: https://console.cloud.google.com
# Steps:
# 1. Create new project
# 2. Enable Geocoding API
# 3. Create API key (restrict to JavaScript/Website)
# 4. Copy key below
VITE_GOOGLE_MAPS_API_KEY=

# ============================================================================
# LOCATION PROVIDER SETTINGS
# ============================================================================

# Provider: "google" or "nominatim" (default: google if key provided, else nominatim)
VITE_LOCATION_PROVIDER=google

# ============================================================================
# ACCURACY THRESHOLDS (in meters)
# ============================================================================

# Mobile devices (GPS-enabled, e.g., smartphones)
# Lower = stricter. Default 150m is production standard
VITE_LOCATION_ACCURACY_MOBILE=150

# Desktop/Laptop (no GPS, browser-based, less accurate)
# Higher threshold due to WiFi/IP-based detection. Default 200m
VITE_LOCATION_ACCURACY_DESKTOP=200

# ============================================================================
# GEOLOCATION TIMEOUT
# ============================================================================

# How long to wait for GPS response (milliseconds)
# Default: 15000 (15 seconds)
VITE_LOCATION_TIMEOUT_MS=15000

# Maximum retry attempts if accuracy is poor
# Default: 2 (3 attempts total: initial + 2 retries)
VITE_LOCATION_MAX_RETRIES=2

# ============================================================================
# STORAGE SETTINGS
# ============================================================================

# localStorage key for persisting location
# Change if you have key conflicts
VITE_LOCATION_STORAGE_KEY=ux_location_v5

# ============================================================================
# API ENDPOINTS (Optional - for custom services)
# ============================================================================

# Custom reverse geocoding endpoint (if using your own service)
# Leave empty to use Google/Nominatim
# VITE_REVERSE_GEOCODE_API=https://your-api.com/geocode

# Custom pincode lookup endpoint
# Leave empty to use Nominatim
# VITE_PINCODE_LOOKUP_API=https://your-api.com/pincode