# Which environment the suite targets: development | staging | production
TEST_ENV=development

# Development (defaults — match vite.config ports)
DEV_API_URL=http://localhost:9000
DEV_CLIENT_URL=http://localhost:5173
DEV_ADMIN_URL=http://localhost:5174
DEV_VENDOR_URL=http://localhost:5175
DEV_DELIVERY_URL=http://localhost:5176

# Staging
STAGING_API_URL=
STAGING_CLIENT_URL=
STAGING_ADMIN_URL=
STAGING_VENDOR_URL=
STAGING_DELIVERY_URL=

# Production (read-only smoke tests recommended)
PROD_API_URL=https://api.urbexon.in
PROD_CLIENT_URL=https://urbexon.in
PROD_ADMIN_URL=https://admin.urbexon.in
PROD_VENDOR_URL=https://vendor.urbexon.in
PROD_DELIVERY_URL=https://delivery.partner.urbexon.in

# Mongo connection for seeding (falls back to backend/.env MONGO_URI)
MONGO_URI=

# Set to 0 to skip DB seeding in global setup
SEED=1

# Set to 1 to enable the auth-endpoint flood test (poisons the rate
# limiter window for 15 min — run isolated)
RATE_LIMIT_FLOOD=0
